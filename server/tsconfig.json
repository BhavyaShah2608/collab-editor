  {
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
      "outDir": "dist",
      "rootDir": "src",
      "module": "CommonJS",
      "moduleResolution": "node",
      "target": "ES2020",
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules"]
  }